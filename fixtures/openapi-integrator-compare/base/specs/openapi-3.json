{
  "openapi": "3.0.3",
  "info": {
    "title": "Task Manager API",
    "version": "2.1.0",
    "description": "Manage tasks and inspect a generated OpenAPI 3 skill layout."
  },
  "servers": [
    {
      "url": "https://tasks.example.com/v1"
    }
  ],
  "paths": {
    "/tasks": {
      "get": {
        "tags": [
          "tasks"
        ],
        "operationId": "list_tasks",
        "summary": "List tasks",
        "responses": {
          "200": {
            "description": "Task list"
          }
        }
      },
      "post": {
        "tags": [
          "tasks"
        ],
        "operationId": "create_task",
        "summary": "Create a task",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "title"
                ],
                "properties": {
                  "title": {
                    "type": "string"
                  },
                  "priority": {
                    "type": "integer",
                    "enum": [
                      1,
                      2,
                      3
                    ]
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer"
      }
    }
  },
  "security": [
    {
      "bearerAuth": []
    }
  ]
}
