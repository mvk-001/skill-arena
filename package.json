{
  "name": "skill-arena",
  "version": "0.1.0",
  "private": false,
  "license": "UNLICENSED",
  "type": "module",
  "keywords": [
    "benchmark",
    "promptfoo",
    "codex",
    "copilot",
    "agent-evaluation"
  ],
  "files": [
    "bin/skill-arena.js",
    "src/**/*.js",
    "README.md"
  ],
  "bin": {
    "skill-arena": "./bin/skill-arena.js"
  },
  "description": "Promptfoo-based benchmark harness for evaluating skills on coding agents.",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "test": "node --test",
    "test:coverage": "c8 --reporter=text --all --include=src/**/*.js --exclude=src/cli/** --exclude=src/runner.js --exclude=src/providers/codex-system-provider.js --exclude=src/providers/pi-system-provider.js --check-coverage --statements 93 --branches 80 --functions 95 --lines 93 node --test",
    "validate:manifest": "node ./src/cli/validate-manifest.js",
    "evolve": "node ./src/cli/evolve-cli.js",
    "generate:config": "node ./src/cli/generate-promptfoo-config.js",
    "run:benchmark": "node ./src/cli/run-benchmark.js",
    "benchmark:compare": "node ./src/cli/run-compare.js",
    "benchmark:smoke:no-skill": "node ./src/cli/run-benchmark.js ./benchmarks/smoke-skill-following/manifest.json --scenario codex-mini-no-skill",
    "benchmark:smoke:skill": "node ./src/cli/run-benchmark.js ./benchmarks/smoke-skill-following/manifest.json --scenario codex-mini-with-skill",
    "benchmark:smoke:compare": "node ./src/cli/run-compare.js ./benchmarks/smoke-skill-following/compare.yaml",
    "benchmark:copilot:compare": "node ./src/cli/run-compare.js ./benchmarks/copilot-cli-smoke-compare/compare.yaml",
    "benchmark:remote:gmail-triage": "node ./src/cli/run-benchmark.js ./benchmarks/remote-gws-gmail-triage/manifest.yaml --scenario codex-mini-with-remote-skill",
    "benchmark:gws:gmail-triage": "node ./src/cli/run-benchmark.js ./benchmarks/gws-gmail-triage/manifest.json --scenario codex-mini-command-with-system-skill"
  },
  "dependencies": {
    "@openai/codex-sdk": "^0.114.0",
    "promptfoo": "^0.121.2",
    "yaml": "^2.8.1",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "c8": "^11.0.0"
  }
}
