{
  "schemaVersion": 1,
  "benchmark": {
    "id": "gws-gmail-triage",
    "description": "Gmail triage benchmark with a system-installed skill.",
    "tags": [
      "gmail",
      "triage",
      "system-installed"
    ]
  },
  "task": {
    "prompt": "Summarize the Gmail triage expectation from the benchmark context."
  },
  "workspace": {
    "fixture": "fixtures/remote-gws-gmail-triage/base",
    "initializeGit": true
  },
  "scenarios": [
    {
      "id": "codex-mini-command-with-system-skill",
      "description": "Codex mini command scenario with the Gmail triage system skill enabled.",
      "skillMode": "enabled",
      "skillSource": "system-installed",
      "agent": {
        "adapter": "codex",
        "model": "gpt-5.1-codex-mini",
        "executionMethod": "command",
        "commandPath": "codex",
        "sandboxMode": "danger-full-access",
        "approvalPolicy": "never",
        "webSearchEnabled": true,
        "networkAccessEnabled": true,
        "reasoningEffort": "low",
        "additionalDirectories": [],
        "cliEnv": {},
        "config": {}
      },
      "evaluation": {
        "assertions": [
          {
            "type": "contains",
            "value": "Gmail"
          }
        ],
        "requests": 1,
        "timeoutMs": 120000,
        "tracing": false,
        "noCache": true
      }
    }
  ]
}
